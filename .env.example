# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous/Public Key (safe to expose in frontend)
# Both names are supported for compatibility
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Project ID (optional, for reference)
VITE_SUPABASE_PROJECT_ID=your-project-id

# For GitHub Actions deployment, also set these as repository secrets:
# - SUPABASE_ACCESS_TOKEN: Personal access token from Supabase dashboard
# - SUPABASE_DB_PASSWORD: Database password for migrations

# ═══════════════════════════════════════════
# Dr. Rose Omnichannel Configuration
# ═══════════════════════════════════════════
# These are set as Supabase Edge Function secrets (not VITE_ prefixed)
# Configure via: supabase secrets set KEY=VALUE --project-ref rgehleqcubtmcwyipyvi

# Lovable AI Gateway (required for Dr. Rose brain)
# LOVABLE_API_KEY=your-lovable-api-key

# Meta WhatsApp Business API
# META_WHATSAPP_TOKEN=your-whatsapp-cloud-api-token
# META_WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id

# Meta Instagram Messaging API
# META_INSTAGRAM_TOKEN=your-instagram-page-token
# META_INSTAGRAM_PAGE_ID=your-instagram-page-id

# Meta Facebook Messenger API
# META_FACEBOOK_TOKEN=your-facebook-page-token
# META_FACEBOOK_PAGE_ID=your-facebook-page-id

# Webhook Verification Token (for Meta webhook setup)
# WEBHOOK_VERIFY_TOKEN=asper_dr_rose_2026

# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous/Public Key (safe to expose in frontend)
# Both names are supported for compatibility
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Project ID (optional, for reference)
VITE_SUPABASE_PROJECT_ID=your-project-id

# Dr. Rose AI Gateway (required by Supabase edge functions)
LOVABLE_API_KEY=your-lovable-gateway-api-key

# Dr. Rose Omnichannel Router (for WhatsApp/Instagram/Facebook/TikTok/custom channels)
# Used for Meta webhook verification challenge on GET ?hub.mode=subscribe
DR_ROSE_WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# Optional callback endpoint that receives generated replies from dr-rose-channel-router
# Example: your automation endpoint that forwards replies to Meta/Twilio/etc
DR_ROSE_CHANNEL_CALLBACK_URL=https://your-automation-endpoint.example.com/dr-rose/reply

# Optional auth/signing for callback requests
DR_ROSE_CHANNEL_CALLBACK_TOKEN=optional-bearer-token
DR_ROSE_CHANNEL_CALLBACK_SECRET=optional-hmac-secret

# For GitHub Actions deployment, also set these as repository secrets:
# - SUPABASE_ACCESS_TOKEN: Personal access token from Supabase dashboard
# - SUPABASE_DB_PASSWORD: Database password for migrations
